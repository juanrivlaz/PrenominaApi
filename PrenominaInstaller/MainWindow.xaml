<Window x:Class="PrenominaInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Instalador Prenomina API" Height="760" Width="880"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}"
        FontFamily="Segoe UI" Foreground="{StaticResource Text}">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="28,22">
            <StackPanel>
                <TextBlock Text="Instalación de Prenomina API" FontSize="22" FontWeight="Bold" />
                <TextBlock Text="Solo captura los valores. El instalador configura el servicio, la base de datos y el firewall por ti."
                           Foreground="{StaticResource Muted}" FontSize="13" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <!-- Formulario -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,22">
            <StackPanel>

                <!-- Base de datos -->
                <TextBlock Text="BASE DE DATOS" FontWeight="Bold" FontSize="12"
                           Foreground="{StaticResource Accent}" Margin="0,0,0,12" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Servidor SQL Server" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="TxtServer" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Usuario" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="TxtUser" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="Contraseña" Style="{StaticResource FieldLabel}" />
                        <PasswordBox x:Name="TxtPassword" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="2" VerticalAlignment="Bottom">
                        <Button Content="Probar conexión" Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Left" Click="OnTestConnection" x:Name="BtnTest" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="0">
                        <TextBlock Text="BD principal (APSI)" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="TxtApsiDb" Text="apsisistemas" />
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="2">
                        <TextBlock Text="BD de prenómina" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="TxtPrenominaDb" Text="PrenominaApi" />
                    </StackPanel>
                </Grid>

                <!-- API -->
                <TextBlock Text="API" FontWeight="Bold" FontSize="12"
                           Foreground="{StaticResource Accent}" Margin="0,28,0,12" />

                <TextBlock Text="Clave JWT (mínimo 32 caracteres)" Style="{StaticResource FieldLabel}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtJwt" Grid.Column="0" />
                    <Button Content="Generar" Grid.Column="2" Style="{StaticResource SecondaryButton}"
                            Click="OnGenerateJwt" />
                </Grid>

                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Puerto" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="TxtPort" Text="5000" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="URL del frontend (CORS) — separa varias con coma" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="TxtWebBase" Text="http://localhost:4200" />
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,14,0,0">
                    <TextBlock Text="Zona horaria (Windows)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="TxtTimeZone" Text="Central Standard Time (Mexico)" />
                </StackPanel>

                <!-- Despliegue API -->
                <TextBlock Text="DESPLIEGUE DEL API" FontWeight="Bold" FontSize="12"
                           Foreground="{StaticResource Accent}" Margin="0,28,0,12" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Ruta de instalación del API" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="TxtInstallPath" Text="C:\PrenominaApi" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Nombre del servicio" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="TxtServiceName" Text="PrenominaApi" />
                    </StackPanel>
                </Grid>

                <!-- Frontend -->
                <Grid Margin="0,28,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="FRONTEND" FontWeight="Bold" FontSize="12"
                               Foreground="{StaticResource Accent}" VerticalAlignment="Center" />
                    <CheckBox Grid.Column="1" x:Name="ChkInstallWeb" IsChecked="True"
                              Content="Instalar también el frontend" Foreground="{StaticResource Muted}"
                              Margin="16,0,0,0" VerticalAlignment="Center"
                              Checked="OnToggleWeb" Unchecked="OnToggleWeb" />
                </Grid>

                <StackPanel x:Name="PanelWeb">
                    <TextBlock Text="URL del API (como la verá el navegador del usuario)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="TxtApiUrl" />

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Puerto web" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="TxtWebPort" Text="80" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Ruta de instalación del frontend" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="TxtWebInstallPath" Text="C:\PrenominaWeb" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Nombre del servicio web" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="TxtWebServiceName" Text="PrenominaWeb" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Log -->
                <TextBlock Text="PROGRESO" FontWeight="Bold" FontSize="12"
                           Foreground="{StaticResource Accent}" Margin="0,28,0,8" />
                <Border Background="{StaticResource Field}" BorderBrush="{StaticResource Border}"
                        BorderThickness="1" CornerRadius="6" Height="170">
                    <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto" Padding="12,8">
                        <TextBox x:Name="TxtLog" IsReadOnly="True" Background="Transparent"
                                 BorderThickness="0" TextWrapping="Wrap" FontFamily="Consolas"
                                 FontSize="12" Foreground="#A7F3D0" />
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Pie -->
        <Border Grid.Row="2" Background="{StaticResource Surface}" Padding="28,16">
            <Grid>
                <TextBlock x:Name="TxtStatus" VerticalAlignment="Center"
                           Foreground="{StaticResource Muted}" FontSize="12" />
                <Button x:Name="BtnInstall" Content="Instalar" Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Right" MinWidth="160" Click="OnInstall" />
            </Grid>
        </Border>
    </Grid>
</Window>
